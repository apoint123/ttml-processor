{
	"name": "ttml-processor",
	"version": "0.3.1",
	"description": "适用于 AMLL 项目的 TTML 歌词解析与生成器",
	"type": "module",
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.mts"
		}
	},
	"files": [
		"dist"
	],
	"license": "MIT",
	"scripts": {
		"build": "tsdown",
		"prepublishOnly": "bun run build",
		"test": "bun test",
		"lint": "bun biome lint .",
		"format": "bun biome format . --fix",
		"typecheck": "bun tsgo -b"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/bun": "=1.3.12",
		"@typescript/native-preview": "=7.0.0-dev.20260419.1",
		"@xmldom/xmldom": "^0.9.10",
		"tsdown": "^0.21.9"
	},
	"packageManager": "bun@1.3.12"
}
