{
	"name": "ttml-processor",
	"version": "0.1.0",
	"description": "适用于 AMLL 项目的 TTML 歌词解析与生成器",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"license": "MIT",
	"scripts": {
		"build": "tsdown",
		"prepublishOnly": "bun run build",
		"test": "bun test",
		"lint": "bun biome lint .",
		"format": "bun biome format . --fix",
		"typecheck": "bun tsc -b"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/bun": "^1.3.10",
		"@xmldom/xmldom": "^0.8.11",
		"tsdown": "^0.21.4"
	},
	"packageManager": "bun@1.3.10"
}
